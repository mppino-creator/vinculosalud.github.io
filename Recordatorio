### 📧 **SISTEMA DE EMAILS - 5 CAPAS DE SEGURIDAD**

```javascript
// citas.js - Validación multicapa
function validarEmailDestinatario(email) {
    const emailsEnviados = new Set(); // Control de duplicados (Set O(1))
    
    // Capa 1: Validación inmediata
    if (email === state.selectedPsych.email) {
        showToast('❌ No puedes usar el email del profesional', 'error');
        return false;
    }
    
    // Capa 2: Verificación contra todos los profesionales
    const todosLosProfesionales = state.staff.map(p => p.email);
    if (todosLosProfesionales.includes(email)) {
        showToast('❌ Este email pertenece a un profesional', 'error');
        return false;
    }
    
    // Capa 3: Flag de envío
    if (window.emailEnviado) {
        console.log('⏭️ Email ya enviado en esta sesión');
        return false;
    }
    
    // Capa 4: Verificación de duplicados por ID
    const emailId = `${Date.now()}_${email}`;
    if (emailsEnviados.has(emailId)) {
        console.log('⏭️ Email duplicado detectado');
        return false;
    }
    emailsEnviados.add(emailId);
    
    // Capa 5: Timeout de seguridad (30s)
    setTimeout(() => emailsEnviados.delete(emailId), 30000);
    
    return true;
}
```

