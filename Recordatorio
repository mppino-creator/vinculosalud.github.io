### 📧 **SISTEMA DE EMAILS - 5 CAPAS DE SEGURIDAD (FINAL)**

```javascript
// citas.js - Validación multicapa CORREGIDA
let emailsEnviados = new Set();
let bookingEnProceso = false;

export function executeBooking() {
    if (bookingEnProceso) return; // Capa 1: Prevenir doble envío
    
    // Capa 2: Validar que email NO sea del profesional
    if (email === state.selectedPsych.email) {
        showToast('❌ No puedes usar el email del profesional', 'error');
        return;
    }
    
    // Capa 3: Verificar contra todos los profesionales
    const todosLosProfesionales = state.staff.map(p => p.email);
    if (todosLosProfesionales.includes(email)) {
        showToast('❌ Este email pertenece a un profesional', 'error');
        return;
    }
    
    // Capa 4: Control de duplicados
    const emailKey = `${email}_${date}_${time}`;
    if (emailsEnviados.has(emailKey)) {
        console.log('⏭️ Email ya enviado');
        return;
    }
    
    // Capa 5: Timeout de seguridad
    emailsEnviados.add(emailKey);
    setTimeout(() => emailsEnviados.delete(emailKey), 30000);
    
    bookingEnProceso = true;
    // ... proceso de reserva
}
