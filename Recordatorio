### **3. Flujo de reserva pública (publico.js)**
```javascript
// Filtra slots disponibles según tipo de atención y rango horario del profesional
export async function updateAvailableTimes() {
    const boxSlots = await loadBoxSlots(date);
    if (type === 'presencial') {
        availableSlots = boxSlots.filter(slot => 
            slot.status === 'available' && dentroRangoProfesional(slot)
        );
    } else {
        // online: muestra todos los slots dentro del rango (aunque estén reservados)
        availableSlots = boxSlots.filter(slot => dentroRangoProfesional(slot));
    }
}

// Reserva: si es presencial, marca el slot como 'booked' con el nombre del profesional
export async function executeBooking() {
    // ... guarda la cita en appointments ...
    if (appointmentType === 'presencial') {
        const boxSlots = await loadBoxSlots(date);
        const slot = boxSlots.find(s => s.timeLabel === timeLabel);
        if (slot && slot.status === 'available') {
            slot.status = 'booked';
            slot.professional = psych.name;
            await saveBoxSlots(date, boxSlots);
        }
    }
}
```

### **4. Confirmación y cancelación de citas presenciales (citas.js)**
```javascript
// Confirmar solicitud presencial (asigna hora)
export async function confirmPresencialTime() {
    const boxSlots = await loadBoxSlots(date);
    const slot = boxSlots.find(s => s.timeLabel === timeLabel);
    if (slot && slot.status === 'available') {
        slot.status = 'booked';
        slot.professional = psych.name;
        await saveBoxSlots(date, boxSlots);
        // crear cita confirmada en appointments
    }
}

// Cancelar cita presencial: libera el slot
export async function cancelAppointment(id) {
    if (appointment.type === 'presencial') {
        const boxSlots = await loadBoxSlots(appointment.date);
        const slot = boxSlots.find(s => s.timeLabel === appointment.time);
        if (slot && slot.status === 'booked') {
            slot.status = 'available';
            slot.professional = null;
            await saveBoxSlots(appointment.date, boxSlots);
        }
    }
    // eliminar cita
}
```

