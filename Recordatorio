```javascript
// Creación de profesional por admin
const randomPassword = Math.random().toString(36).slice(-10);
await firebase.auth().createUserWithEmailAndPassword(email, randomPassword);
await firebase.database().ref(`staff/${uid}`).set(professionalData);
await firebase.auth().sendPasswordResetEmail(email); // profesional elige su clave
```

