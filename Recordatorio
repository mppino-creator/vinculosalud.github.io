## 🔐 **SISTEMA DE PERMISOS v6.7**

```javascript
// permisos.js - 25+ funciones con reintentos automáticos
export async function puedeAccederAPaciente(patientId, intento = 1) {
    if (!state.currentUser && intento < 5) {
        await new Promise(r => setTimeout(r, 100));
        return puedeAccederAPaciente(patientId, intento + 1);
    }
    if (state.currentUser.role === 'admin') return true;
    const patient = state.patients.find(p => p.id == patientId);
    return patient?.psychId == state.currentUser.data.id;
}
```

