export function setCurrentUser(user) { 
    currentUser = user; 
    // Gestión de localStorage con manejo de errores
    if (user) {
        try {
            const userToStore = {
                role: user.role,
                data: { id: user.data.id, name: user.data.name }
            };
            localStorage.setItem('vinculoCurrentUser', JSON.stringify(userToStore));
        } catch (e) {
            if (e.name === 'QuotaExceededError') {
                limpiarStorage();
            }
        }
    }
}
