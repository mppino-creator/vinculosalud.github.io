export function setCurrentUser(user) { 
    currentUser = user; 
    if (user) {
        try {
            localStorage.setItem('vinculoCurrentUser', JSON.stringify({
                role: user.role,
                firebaseUid: user.firebaseUid,
                data: { id: user.data.id, name: user.data.name, email: user.data.email }
            }));
        } catch (e) {
            if (e.name === 'QuotaExceededError') limpiarStorage();
        }
    }
}
