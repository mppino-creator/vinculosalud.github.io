// utils.js - Función de verificación centralizada
export function esEmailProfesional(email) {
    const emailsProfesionales = state.staff
        .map(p => p.email)
        .filter(e => e && e.trim() !== '')
        .map(e => e.trim().toLowerCase());
    
    return emailsProfesionales.includes(email.trim().toLowerCase());
}

