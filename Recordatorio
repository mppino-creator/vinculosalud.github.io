### 🔐 **SISTEMA DE PERMISOS (ACL) - COMPLETO**

```javascript
// permisos.js - 25+ funciones de validación
export async function puedeAccederAPaciente(patientId, intento = 1) {
    // Sistema de reintentos automáticos (5 intentos)
    const user = state.currentUser;
    if (!user && intento < 5) {
        await new Promise(resolve => setTimeout(resolve, 100));
        return puedeAccederAPaciente(patientId, intento + 1);
    }
    
    if (user.role === 'admin') return true; // Admin todo
    if (user.role === 'psych') { // Psicólogo solo sus pacientes
        const patient = state.patients.find(p => p.id == patientId);
        return patient && patient.psychId == user.data.id;
    }
    return false;
}

