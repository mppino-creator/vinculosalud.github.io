#### **Función JavaScript para calcular edad:**
```javascript
window.calcularEdad = function() {
    const birthdate = document.getElementById('custBirthdate').value;
    const edadDisplay = document.getElementById('edadDisplay');
    const tutorSection = document.getElementById('tutorSection');
    
    if (!birthdate) {
        edadDisplay.innerHTML = '';
        tutorSection.style.display = 'none';
        return;
    }
    
    const hoy = new Date();
    const nacimiento = new Date(birthdate);
    let edad = hoy.getFullYear() - nacimiento.getFullYear();
    const mes = hoy.getMonth() - nacimiento.getMonth();
    
    if (mes < 0 || (mes === 0 && hoy.getDate() < nacimiento.getDate())) {
        edad--;
    }
    
    edadDisplay.innerHTML = `<strong>Edad:</strong> ${edad} años`;
    
    if (edad < 18) {
        tutorSection.style.display = 'block';
        document.getElementById('tutorName').required = true;
        document.getElementById('tutorRut').required = true;
        document.getElementById('tutorRelationship').required = true;
    } else {
        tutorSection.style.display = 'none';
        document.getElementById('tutorName').required = false;
        document.getElementById('tutorRut').required = false;
        document.getElementById('tutorRelationship').required = false;
    }
    
    return edad;
};
```

