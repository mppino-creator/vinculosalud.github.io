## 🧠 **PATRONES DE DISEÑO CLAVE**

### **1. Estado global (state.js) - Singleton inmutable**
```javascript
export let staff = [];
export let patients = [];
export let fichasIngreso = [];
export let sesiones = [];
export let informes = [];
export let instagramData = { title, subtitle, quote, text, message, link, image };

// Setters con persistencia en localStorage
export function setCurrentUser(user) {
    currentUser = user;
    if (user) localStorage.setItem('vinculoCurrentUser', JSON.stringify({
        role: user.role,
        firebaseUid: user.firebaseUid,
        data: { id: user.data.id, name: user.data.name, email: user.data.email }
